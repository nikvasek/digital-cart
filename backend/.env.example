PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/digital_cards

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin PIN login
ADMIN_PIN=1111
ADMIN_EMAIL=admin@example.com

# File Storage (можно использовать S3-совместимое хранилище)
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Cloudinary (рекомендуется также поставить STORAGE_TYPE=cloudinary)
# Если ключи заданы, backend автоматически использует Cloudinary для загрузок/удалений.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=digital_cart/gallery

# Email (для уведомлений о лидах)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-password

# Telegram (опционально для уведомлений)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
